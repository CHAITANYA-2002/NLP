### Training Configuration for Hierarchical Contextualized NER
### Use '#' at the start of a line to comment out configuration items

### I/O Paths ###
# Training data in CoNLL format (BIOES tag scheme)
train_dir=sample_data/eng.bioes.train
# Development (validation) data for model selection
dev_dir=sample_data/origin_data/eng.bioes.dev
# Test data for final evaluation
test_dir=sample_data/origin_data/eng.bioes.test
# Prefix for saved model files (e.g., result/lstmcrf.0.model)
model_dir=result/lstmcrf
# Directory for evaluation score output files
result_dir=scores/
# Path to pretrained word embeddings (e.g., GloVe vectors)
word_emb_dir=sample_data/eng.glove
# Path to pretrained label embeddings for label-attention mechanism
label_emb_dir=sample_data/eng.label

### Embedding Settings ###
# Whether to L2-normalize word/char embeddings after loading
norm_word_emb=False
norm_char_emb=False
# Replace digits with '0' to reduce vocabulary sparsity (e.g., '1993' -> '0000')
number_normalized=True
# Whether to use segmentation metrics (entity-level F1 vs token-level accuracy)
seg=True
# Dimensionality of word and character embeddings
word_emb_dim=100
char_emb_dim=32

### Network Configuration ###
# Use CRF layer for structured prediction (vs. softmax)
use_crf=True
# Use character-level features (IntNet)
use_char=True
# Word-level sequence feature extractor: LSTM, GRU, or CNN
word_seq_feature=LSTM
# Sentence-level global feature extractor: LSTM, GRU, or CNN
global_feature_extractor=LSTM
# Character-level feature extractor: IntNet (inception-style multi-scale CNN)
char_seq_feature=IntNet

### Training Settings ###
# Mode: 'train' for training, 'test' for evaluation
status=train
# Optimizer: SGD, Adam, Adagrad, Adadelta, or RMSprop
optimizer=SGD
# Number of training epochs
iteration=70
# Mini-batch size for training
batch_size=10
# Whether to average loss over batch (vs. sum)
ave_batch_loss=False

### Hyperparameters ###
# Number of CNN layers for sentence-level CNN (if using CNN extractor)
cnn_layer=4
# Number of IntNet inception blocks: (intNet_layer - 1) / 2 blocks
intNet_layer=7
# Number of parallel kernel sizes in IntNet (2 = kernel 3 + kernel 5)
intNet_kernel_type=2
# Hidden dimension for character features from IntNet
char_hidden_dim=16
# BiLSTM hidden dimension (split equally between forward/backward)
hidden_dim=256
# Sentence-level global feature hidden dimension
global_hidden_dim=128
# Memory bank interpolation weight: output = (1-alpha)*word + alpha*document
mem_bank_alpha=0.3
# Dropout rate for memory bank retrieval
mem_bank_dropout=0.2
# General dropout rate (applied to embeddings and features)
dropout=0.5
# RNN output dropout rate (applied after BiLSTM)
rnn_dropout=0.5
# Number of BiLSTM layers
lstm_layer=1
# Use bidirectional LSTM (True) or unidirectional (False)
bilstm=True
# Initial learning rate for SGD optimizer
learning_rate=0.015
# Learning rate decay factor: lr = init_lr / (1 + decay * epoch)
lr_decay=0.05
# SGD momentum (0 = no momentum)
momentum=0
# L2 regularization weight (weight decay)
l2=1e-8
# Gradient clipping threshold (commented out = no clipping)
#clip=5
