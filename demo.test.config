### Test/Decode Configuration for Hierarchical Contextualized NER
### This config loads a pre-trained model and evaluates on test data.

# Mode: 'test' to evaluate a trained model (no training)
status=test
# Path to the saved dataset configuration (alphabets, settings, etc.)
# This file is automatically created during training as '<model_dir>.dset'
dset_dir=result/lstmcrf.dset
# Path to the saved model weights to load for evaluation
load_model_dir=result/lstmcrf.model